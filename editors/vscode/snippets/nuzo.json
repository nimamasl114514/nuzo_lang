{
  "fn": {
    "prefix": "fn",
    "body": [
      "fn $1($2) {",
      "    $0",
      "}"
    ],
    "description": "Function definition"
  },
  "if": {
    "prefix": "if",
    "body": [
      "if $1 {",
      "    $0",
      "}"
    ],
    "description": "If statement"
  },
  "ife": {
    "prefix": "ife",
    "body": [
      "if $1 {",
      "    $2",
      "} else {",
      "    $0",
      "}"
    ],
    "description": "If/else statement"
  },
  "for": {
    "prefix": "for",
    "body": [
      "for $1 in $2 {",
      "    $0",
      "}"
    ],
    "description": "For loop"
  },
  "while": {
    "prefix": "while",
    "body": [
      "while $1 {",
      "    $0",
      "}"
    ],
    "description": "While loop"
  },
  "loop": {
    "prefix": "loop",
    "body": [
      "loop {",
      "    $0",
      "}"
    ],
    "description": "Infinite loop"
  },
  "match": {
    "prefix": "match",
    "body": [
      "match $1 {",
      "    $2 => $3,",
      "    _ => $0,",
      "}"
    ],
    "description": "Match expression"
  },
  "try": {
    "prefix": "try",
    "body": [
      "try {",
      "    $0",
      "}"
    ],
    "description": "Try block"
  },
  "tryc": {
    "prefix": "tryc",
    "body": [
      "try {",
      "    $1",
      "} catch ($2) {",
      "    $0",
      "}"
    ],
    "description": "Try/catch block"
  },
  "import": {
    "prefix": "import",
    "body": [
      "import \"$1\" as $0;"
    ],
    "description": "Import module"
  }
}
