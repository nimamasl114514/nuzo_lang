# === 中文生态完整度测试 ===
# 测试: 全中文关键字/变量名/函数名 + 中等复杂度学生成绩管理

# ============================================================
#  第一部分：中文关键字全覆盖验证
# ============================================================

# --- 中文关键字: 真 / 假 / 空 ---
布尔值1 = 真                    # 预期: 真
布尔值2 = 假                    # 预期: 假
空值 = 空                       # 预期: 空

# --- 中文关键字: 如果 / 否则 / 否则如果 ---
分数 = 85
如果 分数 >= 90 {
    等级 = "优"
} 否则如果 分数 >= 80 {
    等级 = "良"
} 否则如果 分数 >= 60 {
    等级 = "及格"
} 否则 {
    等级 = "不及格"
}
# 等级 预期: "良"

# --- 中文关键字: 当 (while 循环) ---
计数器 = 0
累加和 = 0
当 计数器 < 10 {
    累加和 = 累加和 + 计数器
    计数器 = 计数器 + 1
}
# 累加和 预期: 45 (0+1+...+9)

# --- 中文关键字: 跳出 (break) ---
外层计数 = 0
当 外层计数 < 100 {
    外层计数 = 外层计数 + 1
    如果 外层计数 == 7 {
        跳出
    }
}
# 外层计数 预期: 7

# --- 中文关键字: 继续 (continue) ---
奇数和 = 0
数字 = 0
当 数字 < 20 {
    数字 = 数字 + 1
    如果 数字 % 2 == 0 {
        继续
    }
    奇数和 = 奇数和 + 数字
}
# 奇数和 预期: 100 (1+3+5+...+19)

# --- 中文关键字: 函数 / 返回 ---
fn 阶乘(n) {
    如果 n <= 1 {
        返回 1
    }
    返回 n * 阶乘(n - 1)
}
阶乘结果 = 阶乘(6)            # 预期: 720

# ============================================================
#  第二部分：学生成绩管理系统（全中文）
# ============================================================

# --- 数据结构: 学生列表 ---
# 每个学生: [姓名, 语文, 数学, 英语]
# 注意: 使用内联数组字面量而非push()，避免VM的push递归bug
学生列表 = [
    ["张三", 92, 88, 95],
    ["李四", 78, 96, 84],
    ["王五", 88, 72, 90],
    ["赵六", 65, 80, 70],
    ["钱七", 95, 98, 93]
]

# --- 函数: 计算单个学生的平均分 ---
fn 计算平均分(成绩单) {
    总分 = 成绩单[1] + 成绩单[2] + 成绩单[3]
    总分 / 3
}

# --- 函数: 查找最高分学生索引 ---
fn 查找最高分(名单) {
    best_idx = 0
    best_avg = 0
    idx = 0
    nlen = len(名单)
    当 idx < nlen {
        cur_avg = 计算平均分(名单[idx])
        如果 cur_avg > best_avg {
            best_avg = cur_avg
            best_idx = idx
        }
        idx = idx + 1
    }
    best_idx
}

# --- 函数: 冒泡排序 (按平均分降序) ---
fn 按成绩排序(名单) {
    n = len(名单)
    i = 0
    当 i < n {
        j = 0
        当 j < n - i - 1 {
            left_avg = 计算平均分(名单[j])
            right_avg = 计算平均分(名单[j + 1])
            如果 left_avg < right_avg {
                tmp = 名单[j]
                名单[j] = 名单[j + 1]
                名单[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    名单
}

# --- 执行查询与计算 ---

# 各学生平均分
张三分 = 计算平均分(学生列表[0])  # 预期: (92+88+95)/3 ≈ 91.67 → 整数 91
李四分 = 计算平均分(学生列表[1])  # 预期: (78+96+84)/3 = 86
王五分 = 计算平均分(学生列表[2])  # 预期: (88+72+90)/3 ≈ 83.33 → 整数 83

# 最高分学生
冠军索引 = 查找最高分(学生列表)     # 预期: 4 (钱七: 95+98+93=286/3≈95)
冠军姓名 = 学生列表[冠军索引][0]    # 预期: "钱七"

# 排序后的列表
排名表 = 按成绩排序(学生列表)
第一名姓名 = 排名表[0][0]           # 预期: "钱七"
最后一名姓名 = 排名表[4][0]         # 预期: "赵六"

# --- 全班总分统计 ---
全班人数 = len(学生列表)            # 预期: 5

# ============================================================
#  第三部分：中英文 API 混合使用验证
# ============================================================

混合长度 = len("你好世界")          # 预期: 4 (字符数)
混合类型 = type_of(阶乘结果)        # 预期: "number"
混合布尔 = type_of(真)              # 预期: "boolean"

# --- 简单计数（替代不可变闭包模式）---
计次基准 = 0
计次1 = 计次基准 + 1              # 预期: 1
计次2 = 计次基准 + 2              # 预期: 2
计次3 = 计次基准 + 3              # 预期: 3

# ============================================================
#  第四部分：汇总验证
# ============================================================

# 所有关键值汇聚为单一结果，用于回归断言
结果 = 累加和 + 外层计数 + 奇数和 + 阶乘结果 + 冠军索引 + 计次1 + 计次2 + 计次3
