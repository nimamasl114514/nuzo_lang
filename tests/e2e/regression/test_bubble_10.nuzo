# 真实 bubble_sort (10元素)
fn bubble_sort(arr) {
    result = []
    i = 0
    while i < arr.length {
        push(result, arr[i])
        i = i + 1
    }
    n = result.length
    swapped = 1
    while swapped {
        swapped = 0
        i = 0
        while i < n - 1 {
            if result[i] > result[i+1] {
                temp = result[i]
                result[i] = result[i+1]
                result[i+1] = temp
                swapped = 1
            }
            i = i + 1
        }
        n = n - 1
    }
    result
}

# 创建测试数据
data = []
i = 0
while i < 10 {
    push(data, 10 - i)
    i = i + 1
}

# 执行排序
sorted = bubble_sort(data)
sorted[0]
