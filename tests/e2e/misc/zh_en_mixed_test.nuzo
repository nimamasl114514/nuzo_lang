# === 中英文无缝混合编程测试 ===
# 目标: 验证同一个文件中中英文关键字可以自由混用

# --- 测试1: 基础控制流混合 ---
en_result = 0
x = 10
如果 x > 5 {          # 中文 if
    en_result = en_result + 1
} else {              # 英文 else
    en_result = en_result + 10
}
# en_result 预期: 11

# --- 测试2: 循环混合 ---
cn_sum = 0
i = 0
当 i < 5 {           # 中文 while
    cn_sum = cn_sum + i
    i = i + 1
}
# cn_sum 预期: 10 (0+1+2+3+4)

# --- 测试3: 函数定义与调用混合 ---
fn add(a, b) {       # 英文 fn
    返回 a + b        # 中文 return
}

fn 阶乘(n) {          # 中文 fn
    如果 n <= 1 {     # 中文 if
        return 1      # 英文 return
    } 否则 {          # 中文 else
        返回 n * 阶乘(n - 1)  # 混合调用
    }
}

test_add = add(3, 4)           # test_add 预期: 7
test_fact = 阶乘(5)            # test_fact 预期: 120

# --- 测试4: for 循环混合 ---
arr = [1, 2, 3, 4, 5]
for_sum = 0
for item 在 arr {     # 英文 for + 中文 in
    for_sum = for_sum + item
}
# for_sum 预期: 15

# --- 测试5: 逻辑运算符混合 ---
bool1 = 真            # 中文 true
bool2 = false         # 英文 false
bool3 = bool1 and bool2   # 英文 and
bool4 = bool1 || 假       # 英文 || + 中文 false
# bool3 预期: false (假)
# bool4 预期: true (真)

# --- 测试6: break/continue 混合 ---
loop_count = 0
loop_sum = 0
loop {
    loop_count = loop_count + 1
    if loop_count > 10 {
        跳出              # 中文 break
    }
    if loop_count % 2 == 0 {
        continue          # 英文 continue
    }
    loop_sum = loop_sum + loop_count
}
# loop_count 预期: 11
# loop_sum 预期: 25 (1+3+5+7+9)

# --- 测试7: 闭包混合 ---
fn make_adder(x) {
    return fn(y) {    # 英文 return + fn
        返回 x + y     # 中文 return
    }
}

add5 = make_adder(5)
closure_result = add5(3)
# closure_result 预期: 8

# --- 测试8: 复杂嵌套混合 ---
fn complex_mix(n) {
    result = 0
    i = 0
    while i < n {              # 英文 while
        j = 0
        当 j < n {             # 中文 while
            if i == j {        # 英文 if
                result = result + i
            }
            j = j + 1
        }
        i = i + 1
    }
    return result              # 英文 return
}

complex_result = complex_mix(5)
# complex_result 预期: 15 (0+1+2+3+4 对角线)

# --- 最终汇总 ---
final_result = en_result + cn_sum + test_add + test_fact + for_sum + loop_count + loop_sum + closure_result + complex_result
# final_result 预期: 11 + 10 + 7 + 120 + 15 + 11 + 25 + 8 + 15 = 222
