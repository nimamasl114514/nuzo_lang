# Nuzo 编译能力测试 - 扁平化 (200行)
# 目标：验证编译器能处理200+行代码而不溢出寄存器

# ============================================================
# 模块1: 简单数学函数 (40行)
# ============================================================

fn add(a, b) { a + b }
fn sub(a, b) { a - b }
fn mul(a, b) { a * b }
fn div(a, b) { a / b }
fn mod(a, b) { a % b }
fn neg(x) { 0 - x }
fn abs(x) { 如果 x < 0 { neg(x) } 否则 { x } }
fn sq(x) { x * x }
fn cube(x) { x * x * x }

fn clamp(x, lo, hi) {
    如果 x < lo { lo } 否则 { 如果 x > hi { hi } 否则 { x } }
}

# ============================================================
# 模块2: 简单统计函数 (40行)
# ============================================================

fn sum4(a, b, c, d) { a + b + c + d }
fn avg4(a, b, c, d) { sum4(a, b, c, d) / 4 }
fn min3(a, b, c) {
    m = 如果 a < b { a } 否则 { b }
    如果 m < c { m } 否则 { c }
}
fn max3(a, b, c) {
    m = 如果 a > b { a } 否则 { b }
    如果 m > c { m } 否则 { c }
}
fn range(a, b) { b - a }
fn mid(a, b, c) {
    sum = a + b + c
    sum - min3(a, b, c) - max3(a, b, c)
}

# ============================================================
# 模块3: 数论函数 (40行)
# ============================================================

fn even(n) { 如果 n % 2 == 0 { 1 } 否则 { 0 } }
fn odd(n) { 如果 n % 2 != 0 { 1 } 否则 { 0 } }
fn pos(n) { 如果 n > 0 { 1 } 否则 { 0 } }
fn neg_check(n) { 如果 n < 0 { 1 } 否则 { 0 } }
fn zero(n) { 如果 n == 0 { 1 } 否则 { 0 } }
fn sign(n) {
    如果 n > 0 { 1 } 否则 { 如果 n < 0 { 0 - 1 } 否则 { 0 } }
}

fn div2(n) { n / 2 }
fn mul2(n) { n * 2 }
fn mul10(n) { n * 10 }
fn inc(n) { n + 1 }
fn dec(n) { n - 1 }

# ============================================================
# 模块4: 位操作模拟 (30行)
# ============================================================

fn and_bit(a, b) {
    如果 a != 0 { 如果 b != 0 { 1 } 否则 { 0 } } 否则 { 0 }
}
fn or_bit(a, b) {
    如果 a != 0 { 1 } 否则 { 如果 b != 0 { 1 } 否则 { 0 } }
}
fn not_bit(a) { 如果 a == 0 { 1 } 否则 { 0 } }
fn xor_bit(a, b) { or_bit(and_bit(a, not_bit(b)), and_bit(not_bit(a), b)) }

# ============================================================
# 模块5: 逻辑函数 (30行)
# ============================================================

fn imply(a, b) { 如果 a == 1 { b } 否则 { 1 } }
fn eqv(a, b) { 如果 a == b { 1 } 否则 { 0 } }
fn nand(a, b) { not_bit(and_bit(a, b)) }
fn nor(a, b) { not_bit(or_bit(a, b)) }

fn in_range(x, lo, hi) { 如果 x >= lo { 如果 x <= hi { 1 } 否则 { 0 } } 否则 { 0 } }
fn between(x, a, b) { 如果 x > a { 如果 x < b { 1 } 否则 { 0 } } 否则 { 0 } }

# ============================================================
# 主程序：大量独立测试 (50行)
# ============================================================

# 数学测试组1
t1 = add(10, 20)
t2 = sub(100, 37)
t3 = mul(6, 7)
t4 = div(100, 5)
t5 = mod(17, 5)

# 数学测试组2
t6 = abs(0 - 42)
t7 = abs(0)
t8 = abs(99)
t9 = sq(12)
t10 = cube(5)

# 数学测试组3
t11 = clamp(15, 0, 100)
t12 = clamp(0 - 5, 0, 100)
t13 = clamp(150, 0, 100)

# 统计测试
t14 = sum4(1, 2, 3, 4)
t15 = avg4(10, 20, 30, 40)
t16 = min3(5, 2, 8)
t17 = max3(5, 2, 8)
t18 = mid(1, 5, 9)

# 数论测试
t19 = even(4)
t20 = odd(7)
t21 = sign(0 - 99)
t22 = sign(0)
t23 = sign(42)
t24 = inc(99)
t25 = dec(100)

# 位操作测试
t26 = and_bit(1, 1)
t27 = or_bit(1, 0)
t28 = xor_bit(1, 1)
t29 = not_bit(1)

# 逻辑测试
t30 = imply(1, 0)
t31 = eqv(1, 1)
t32 = in_range(5, 0, 10)
t33 = between(5, 0, 10)

# 最终汇总
final = t1 + t2 + t3 + t4 + t5 +
        t6 + t7 + t8 + t9 + t10 +
        t11 + t12 + t13 + t14 + t15 +
        t16 + t17 + t18 + t19 + t20 +
        t21 + t22 + t23 + t24 + t25 +
        t26 + t27 + t28 + t29 + t30 +
        t31 + t32 + t33

final
