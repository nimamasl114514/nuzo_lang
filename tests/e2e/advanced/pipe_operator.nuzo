# === 管道运算符测试 ===
# 测试: |> 管道运算符的链式调用和脱糖

# --- 基本管道 ---
fn double(x) { x * 2 }
fn inc(x) { x + 1 }

r1 = 5 |> double
# r1 预期: 10

r2 = 5 |> double |> inc
# r2 预期: 11

# --- 管道带参数调用 ---
fn add(a, b) { a + b }
r3 = 10 |> add(20)
# r3 预期: 30

# --- 管道链式 ---
r4 = 3 |> double |> double |> inc
# r4 预期: 13

# --- 管道与字面量 ---
r5 = 100 |> double |> inc
# r5 预期: 201

# --- 管道与闭包 ---
apply = fn(f, x) { f(x) }
r6 = 7 |> double |> apply(inc)
# r6 预期: 15

# --- 汇总 ---
result = r1 + r2 + r3 + r4 + r5 + r6
