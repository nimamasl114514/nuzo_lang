# Nuzo Performance Benchmark (轻量化版)
# 减少计算量避免进程崩溃

fn fib_iter(n) {
    如果 n <= 0 { 返回 0 }
    如果 n == 1 { 返回 1 }
    a = 0
    b = 1
    i = 2
    当 i <= n {
        temp = a + b
        a = b
        b = temp
        i = i + 1
    }
    b
}

fn array_test(size) {
    arr = []
    i = 0
    当 i < size {
        push(arr, i * 2)
        i = i + 1
    }
    sum = 0
    j = 0
    当 j < len(arr) {
        sum = sum + arr[j]
        j = j + 1
    }
    sum
}

fn factorial_iter(n) {
    result = 1
    i = 2
    当 i <= n {
        result = result * i
        i = i + 1
    }
    result
}

# 执行基准测试（缩减规模）
fib_result = fib_iter(15)
arr_sum = array_test(100)
fact_result = factorial_iter(10)

# 汇总结果
fib_result + arr_sum + fact_result
