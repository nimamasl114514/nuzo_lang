# === GC 内存压力测试 (轻量版) ===
# 测试GC在高频分配/释放下的稳定性
# 注意: 当前VM的GC对字典循环引用使用递归标记，会导致栈溢出
# 此测试改为单向引用 + 高频分配来验证GC基本正确性

# 高频创建和丢弃对象（触发GC回收）
i = 0
total = 0
当 i < 50 {
    d = {}
    d["data"] = i * 10
    d["name"] = "obj_" + i
    total = total + d["data"]
    i = i + 1
}

# 验证大数组操作后GC正常
arr = []
j = 0
当 j < 500 {
    push(arr, j * 3)
    j = j + 1
}
sum = 0
k = 0
当 k < len(arr) {
    sum = sum + arr[k]
    k = k + 1
}

total + sum
