# ============================================================
# Nuzo 综合复杂测试 - 算法 + 函数式编程 + 数学计算
# 覆盖: 递归/闭包/高阶函数/数组/控制流/中文关键字
# ============================================================

# ==================== 第一部分: 经典算法 ====================

# 1. 快速幂 (迭代版本)
fn fast_pow(base, exp) {
    result = 1
    i = 0
    当 i < exp {
        result = result * base
        i = i + 1
    }
    返回 result
}

# 2. 二分查找 (简化版: 线性扫描模拟)
fn binary_search(arr, target) {
    left = 0
    right = len(arr) - 1
    result = -1
    当 left <= right {
        如果 arr[left] == target {
            result = left
            跳出
        }
        left = left + 1
    }
    返回 result
}

# 3. 插入排序
fn insertion_sort(arr) {
    如果 len(arr) <= 1 {
        返回 arr
    }
    result = []
    push(result, arr[0])

    i = 1
    当 i < len(arr) {
        val = arr[i]
        j = len(result) - 1
        当 j >= 0 && result[j] > val {
            push(result, result[j])  # 占位，后续覆盖
            j = j - 1
        }
        # 插入到正确位置
        push(result, val)
        i = i + 1
    }

    返回 result
}

# 4. 冒泡排序
fn bubble_sort(arr) {
    result = []
    i = 0
    当 i < len(arr) {
        push(result, arr[i])
        i = i + 1
    }
    n = len(result)
    i = 0
    当 i < n {
        j = 0
        当 j < n - i - 1 {
            如果 result[j] > result[j + 1] {
                temp = result[j]
                result[j] = result[j + 1]
                result[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    返回 result
}

# ==================== 第二部分: 函数式编程 ====================

# 5. 柯里化加法
fn curry_add(a) {
    fn(b) {
        fn(c) {
            a + b + c
        }
    }
}

# 6. 组合函数
fn compose(f, g) {
    fn(x) {
        f(g(x))
    }
}

# 7. 偏应用
fn partial(fn_, fixed_arg) {
    fn(x) {
        fn_(fixed_arg, x)
    }
}

# 8. Y组合子演示 (迭代阶乘)
fn y_combinator_demo(n) {
    result = 1
    i = 2
    当 i <= n {
        result = result * i
        i = i + 1
    }
    返回 result
}

# ==================== 第三部分: 闭包与状态 ====================

# 9. 计数器工厂
fn make_counter(start) {
    count = start
    fn() {
        count = count + 1
        返回 count
    }
}

# 10. 累加器
fn make_accumulator(init) {
    total = init
    fn(value) {
        total = total + value
        返回 total
    }
}

# ==================== 第四部分: 数学计算 ====================

# 11. 牛顿法求平方根
fn sqrt_newton(n) {
    如果 n < 0 {
        返回 空
    } 否则 如果 n == 0 {
        返回 0
    } 否则 {
        x = n
        i = 0
        当 i < 20 {
            x = (x + n / x) / 2
            i = i + 1
        }
        返回 x
    }
}

# 12. 数值积分 (梯形法则)
fn integrate(fn_, a, b, n_steps) {
    h = (b - a) / n_steps
    sum = (fn_(a) + fn_(b)) / 2
    i = 1
    当 i < n_steps {
        sum = sum + fn_(a + i * h)
        i = i + 1
    }
    返回 sum * h
}

# 13. 斐波那契 (迭代版)
fn fib_iter(n) {
    如果 n <= 1 {
        返回 n
    }
    a = 0
    b = 1
    i = 2
    当 i <= n {
        c = a + b
        a = b
        b = c
        i = i + 1
    }
    返回 b
}

# 14. 阶乘 (递归版)
fn factorial_rec(n) {
    如果 n <= 1 { 返回 1 }
    返回 n * factorial_rec(n - 1)
}

# 15. 素数判断
fn is_prime(n) {
    如果 n < 2 { 返回 假 }
    i = 2
    当 i * i <= n {
        如果 n % i == 0 { 返回 假 }
        i = i + 1
    }
    返回 真
}

# 16. 素数计数
fn count_primes(limit) {
    count = 0
    k = 2
    当 k < limit {
        如果 is_prime(k) { count = count + 1 }
        k = k + 1
    }
    返回 count
}

# 17. 字符串构建
fn build_label(name, score) {
    name + ": " + score
}

# 18. 链式调用测试
fn chain_test() {
    fn add1(x) { x + 1 }
    fn mul2(x) { x * 2 }
    fn sub3(x) { x - 3 }
    # ((5 + 1) * 2 - 3) = 9
    返回 sub3(mul2(add1(5)))
}

