# 数组索引赋值核心测试 v2.0
# 精简版本，避免超过256个寄存器限制

# ============================================================
# 测试1: 基础赋值 + 覆盖 + 类型
# ============================================================

arr = [0, 0, 0, 0, 0]
arr[0] = 10
arr[1] = 20
arr[2] = 30
arr[3] = 40
arr[4] = 50

# 覆盖赋值
arr[0] = 99

# 不同类型
arr[1] = -5
arr[2] = 10000

test1 = arr[0] + arr[1] + arr[2] + arr[3] + arr[4]  # 99 + (-5) + 10000 + 40 + 50 = 10184

# ============================================================
# 测试2: 表达式索引
# ============================================================

arr2 = [0, 0, 0, 0, 0]
i = 0
arr2[i] = 77
i = i + 1
arr2[i] = 88
i = i + 1
arr2[i] = 99

# 算术表达式索引
arr2[1 + 2] = 66  # arr2[3] = 66

test2 = arr2[0] + arr2[1] + arr2[2] + arr2[3] + arr2[4]  # 77 + 88 + 99 + 66 + 0 = 330

# ============================================================
# 测试3: 表达式作为值
# ============================================================

arr3 = [0, 0, 0]
arr3[0] = 10 + 20
arr3[1] = 100 / 2
arr3[2] = 3 * 7

test3 = arr3[0] + arr3[1] + arr3[2]  # 30 + 50 + 21 = 101

# ============================================================
# 测试4: 索引赋值（预分配避免越界）
# ============================================================

arr4 = [1, 2, 3, 0, 0, 0, 0, 0, 0, 0, 0]
arr4[10] = 999  # 预分配11元素，安全赋值

test4a = arr4[10]   # 999
test4b = arr4[0] + arr4[1] + arr4[2]  # 6 (原始保持)

# 预分配空数组
arr5 = [0, 0, 0, 0, 0, 0]
arr5[0] = 42
arr5[5] = 100

test4c = arr5[0] + arr5[5]  # 142

# ============================================================
# 测试5: 数组间复制和运算
# ============================================================

src = [100, 200, 300]
dst = [0, 0, 0]
dst[0] = src[0] * 2
dst[1] = src[2] / 10
dst[2] = src[1] - src[0]

test5 = dst[0] + dst[1] + dst[2]  # 200 + 30 + 100 = 330

# ============================================================
# 最终结果
# ============================================================
final = test1 + test2 + test3 + test4a + test4b + test4c + test5
