# === 05 变量 ===
# 测试: 声明、赋值、重新赋值、作用域

# --- 声明与赋值 ---
x = 10                  # 预期: 10
y = 20                  # 预期: 20

# --- 重新赋值 ---
x = 30                  # 预期: 30
y = x + 5               # 预期: 35

# --- 变量运算 ---
sum_xy = x + y          # 预期: 65

# --- 块作用域 ---
outer = 100
如果 真 {
    inner = 200
    outer = outer + inner  # 预期: 300
}

# --- 变量在循环中使用 ---
i = 0
acc = 0
当 i < 5 {
    acc = acc + i
    i = i + 1
}
# acc 预期: 0+1+2+3+4 = 10

# --- 汇总 ---
result = sum_xy + outer + acc
