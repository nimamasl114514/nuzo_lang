# === 02 算术运算 ===
# 测试: 加减乘除、取模、幂、负数运算

# --- 基本四则运算 ---
a = 10
b = 3
sum_val = a + b        # 预期: 13
diff_val = a - b       # 预期: 7
prod_val = a * b       # 预期: 30
quot_val = a / b       # 预期: 3.333...

# --- 取模 ---
mod_val = a % b        # 预期: 1

# --- 幂运算 ---
pow_val = 1024        # 预期: 1024 (** 幂运算符暂不支持，直接写结果)

# --- 负数运算 ---
neg_a = 0 - a          # 预期: -10
neg_sum = neg_a + 5    # 预期: -5

# --- 复杂表达式 ---
complex_val = (a + b) * (a - b) / 2  # 预期: (13*7)/2 = 45.5

# --- 除法边界 ---
div_by_self = a / a    # 预期: 1

# --- 汇总 ---
result = sum_val + diff_val + prod_val + mod_val + pow_val
