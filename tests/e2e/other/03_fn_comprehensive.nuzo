# 命名函数完整性测试 v2.0
# 使用科学方法验证：观察→假设→实验→证伪

# ============================================================
# 测试组1: 基础功能 (验证假设H1)
# ============================================================

# 1.1 两参数加法函数
fn add(a, b) {
    a + b
}

# 1.2 单参数乘法函数
fn double(x) {
    x * 2
}

# 1.3 幂函数
fn square(x) {
    x * x
}

# 1.4 组合调用测试 (预期: 30 + 10 + 9 = 49)
result_basic = add(10, 20) + double(5) + square(3)

# ============================================================
# 测试组2: 多参数函数 (验证参数传递)
# ============================================================

# 2.1 三参数函数
fn sum3(a, b, c) {
    a + b + c
}

result_multi = sum3(1, 2, 3)  # 预期: 6

# 2.2 四参数函数
fn sum4(a, b, c, d) {
    a + b + c + d
}

result_4param = sum4(1, 2, 3, 4)  # 预期: 10

# ============================================================
# 测试组3: 递归函数 (验证栈帧管理)
# ============================================================

# 3.1 阶乘函数
fn factorial(n) {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

result_fact = factorial(5)  # 预期: 120

# 3.2 斐波那契数列
fn fib(n) {
    if n <= 1 {
        n
    } else {
        fib(n - 1) + fib(n - 2)
    }
}

result_fib = fib(10)  # 预期: 55

# ============================================================
# 测试组4: 嵌套调用与链式调用 (验证寄存器管理)
# ============================================================

# 4.1 嵌套调用: double(add(1, 2)) => double(3) => 6
result_nested = double(add(1, 2))  # 预期: 6

# 4.2 链式调用: add(add(1, 2), add(3, 4)) => add(3, 7) => 10
result_chain = add(add(1, 2), add(3, 4))  # 预期: 10

# 4.3 混合复杂表达式
result_complex = square(double(add(1, 2)))  # 预期: square(double(3)) => square(6) => 36

# ============================================================
# 测试组5: 边界情况 (证伪法：尝试破坏)
# ============================================================

# 5.1 无参数函数
fn constant() {
    42
}

result_no_param = constant()  # 预期: 42

# 5.2 单参数恒等函数
fn identity(x) {
    x
}

result_identity = identity(99)  # 预期: 99

# 5.3 返回字面量
fn return_true() {
    1
}

fn return_false() {
    0
}

result_bool_test = return_true() + return_false()  # 预期: 1

# 5.4 负数运算
fn negate(x) {
    0 - x
}

result_negate = negate(5)  # 预期: -5

# 5.5 大数运算
fn big_add(a, b) {
    a + b
}

result_big = big_add(10000, 20000)  # 预期: 30000

# ============================================================
# 最终结果汇总
# ============================================================
final_result = result_basic + result_multi + result_4param + result_fact + result_fib + result_nested + result_chain + result_complex + result_no_param + result_identity + result_bool_test + result_negate + result_big
