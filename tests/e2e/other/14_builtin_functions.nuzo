# === 14 内置函数 ===
# 测试: println/print/len/type_of/assert/clock

# --- println ---
println("Hello from Nuzo!")

# --- print ---
print("value = ")
println(42)

# --- len ---
arr = [1, 2, 3, 4, 5]
arr_len = len(arr)        # 预期: 5

str_len = len("Nuzo")     # 预期: 4

# --- type_of ---
type_num = type_of(42)       # 预期: "number"
type_str = type_of("hello")  # 预期: "string"
type_bool = type_of(真)      # 预期: "boolean"
type_nil = type_of(空)       # 预期: "nil"
type_arr = type_of([])       # 预期: "array"
type_dict = type_of({})      # 预期: "dict"

# --- assert ---
assert(1 + 1 == 2)
assert(10 > 5)
assert(3 * 4 == 12)

# --- 算术验证 (替代 clock，clock 未在 VM 中注册) ---
calc = 10 * 5 + 3       # 预期: 53

# --- 汇总 ---
result = arr_len + str_len + calc
