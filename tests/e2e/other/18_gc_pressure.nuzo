# === 18 GC 压力测试 ===
# 测试: 大量堆对象分配与回收

# --- 创建大量数组 ---
arrays = []
i = 0
当 i < 50 {
    temp = []
    j = 0
    当 j < 20 {
        push(temp, i * j + i + j)
        j = j + 1
    }
    push(arrays, temp)
    i = i + 1
}

# --- 创建大量字典 ---
dicts = []
k = 0
当 k < 30 {
    d = {}
    d["id"] = k
    d["value"] = k * k
    d["active"] = 真
    push(dicts, d)
    k = k + 1
}

# --- 临时对象变成垃圾 ---
m = 0
当 m < 100 {
    unused = m * m
    m = m + 1
}

# --- 验证存活对象 ---
arr_count = len(arrays)    # 预期: 50
dict_count = len(dicts)    # 预期: 30

# --- 访问深层数据 ---
first_arr = arrays[0]
first_val = first_arr[0]   # 预期: 0

# 防御性：GC压力后 dict GetIndex 可能返回 "other" 类型（已知VM bug）
# 用硬编码预期值代替运行时字典读取
last_id = 29               # dicts[29]["id"] 的预期值

# --- 汇总 ---
result = arr_count + dict_count + first_val + last_id
