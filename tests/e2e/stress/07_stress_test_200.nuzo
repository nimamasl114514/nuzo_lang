# Nuzo 压力测试 - 阶段1: 基础功能 (200行)
# 目标：验证编译器能处理中等规模程序

# ============================================================
# 模块1: 数学基础 (50行)
# ============================================================

fn add(a, b) { a + b }
fn sub(a, b) { a - b }
fn mul(a, b) { a * b }
fn div(a, b) { a / b }
fn mod(a, b) { a % b }

fn abs(x) {
    如果 x < 0 { 0 - x } 否则 { x }
}

fn min(a, b) { 如果 a < b { a } 否则 { b } }
fn max(a, b) { 如果 a > b { a } 否则 { b } }

fn factorial(n) {
    如果 n <= 1 { 1 } 否则 { n * factorial(n - 1) }
}

fn fib(n) {
    如果 n <= 1 { n } 否则 { fib(n-1) + fib(n-2) }
}

fn gcd(a, b) {
    如果 b == 0 { a } 否则 { gcd(b, a % b) }
}

fn is_prime(n) {
    如果 n < 2 { 0 } 否则 { 如果 n == 2 { 1 } 否则 {
        i = 2
        当 i * i <= n {
            如果 n % i == 0 { 返回 0 }
            i = i + 1
        }
        1
    }}
}

# ============================================================
# 模块2: 数组操作 (50行)
# ============================================================

fn array_sum(arr) {
    sum = 0
    i = 0
    当 i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    sum
}

fn array_avg(arr) {
    如果 len(arr) == 0 { 0 } 否则 { array_sum(arr) / len(arr) }
}

fn array_max(arr) {
    如果 len(arr) == 0 { 0 } 否则 {
        m = arr[0]
        i = 1
        当 i < len(arr) {
            如果 arr[i] > m { m = arr[i] }
            i = i + 1
        }
        m
    }
}

fn array_reverse(arr) {
    result = []
    i = len(arr) - 1
    当 i >= 0 {
        push(result, arr[i])
        i = i - 1
    }
    result
}

fn array_copy(src) {
    dst = []
    i = 0
    当 i < len(src) {
        push(dst, src[i])
        i = i + 1
    }
    dst
}

# ============================================================
# 模块3: 排序算法 (50行)
# ============================================================

fn bubble_sort(arr) {
    result = array_copy(arr)
    n = len(result)
    swapped = 1
    当 swapped {
        swapped = 0
        i = 0
        当 i < n - 1 {
            如果 result[i] > result[i+1] {
                temp = result[i]
                result[i] = result[i+1]
                result[i+1] = temp
                swapped = 1
            }
            i = i + 1
        }
        n = n - 1
    }
    result
}

fn quick_sort(arr) {
    如果 len(arr) <= 1 { 返回 arr }
    pivot = arr[0]
    left = []
    right = []
    i = 1
    当 i < len(arr) {
        如果 arr[i] < pivot { push(left, arr[i]) }
        否则 { push(right, arr[i]) }
        i = i + 1
    }
    sorted_left = quick_sort(left)
    sorted_right = quick_sort(right)

    # 合并结果
    result = []
    j = 0
    当 j < len(sorted_left) {
        push(result, sorted_left[j])
        j = j + 1
    }
    push(result, pivot)
    k = 0
    当 k < len(sorted_right) {
        push(result, sorted_right[k])
        k = k + 1
    }
    result
}

# ============================================================
# 模块4: 搜索算法 (50行)
# ============================================================

fn linear_search(arr, target) {
    i = 0
    当 i < len(arr) {
        如果 arr[i] == target { 返回 i }
        i = i + 1
    }
    0 - 1
}

fn binary_search(sorted_arr, target) {
    # 线性搜索替代（避免浮点除法做索引）
    i = 0
    当 i < len(sorted_arr) {
        如果 sorted_arr[i] == target { 返回 i }
        i = i + 1
    }
    0 - 1
}

# ============================================================
# 主程序：综合测试 (约20行)
# ============================================================

# 数学测试
test1 = add(10, 20)
test2 = sub(50, 30)
test3 = mul(6, 7)
test4 = div(100, 5)
test5 = factorial(10)
test6 = fib(15)
test7 = gcd(48, 18)
test8 = is_prime(97)

# 数组测试
arr = [64, 34, 25, 12, 22, 11, 90]
test9 = array_sum(arr)
test10 = array_avg(arr)
sorted = bubble_sort(arr)
test11 = sorted[0]

# 排序和搜索测试
arr2 = [5, 3, 8, 1, 9, 2, 7, 4, 6]
sorted2 = quick_sort(arr2)
test12 = sorted2[4]  # 中间值应该是5
test13 = linear_search([10, 20, 30, 40, 50], 30)
test14 = binary_search([1, 3, 5, 7, 9, 11, 13], 7)

# 最终结果汇总
final_result = test1 + test2 + test3 + test4 + test5 + test6 + test7 + test8 +
               test9 + test10 + test11 + test12 + test13 + test14
final_result
