# 命名函数压力测试 (证伪法)
# 目的：主动尝试证明"命名函数有bug"

# ============================================================
# 攻击向量1: 深层递归 (栈溢出测试)
# ============================================================

fn deep_recursion(n) {
    if n <= 0 {
        0
    } else {
        1 + deep_recursion(n - 1)
    }
}

result_deep = deep_recursion(100)  # 预期: 100

# ============================================================
# 攻击向量2: 高阶函数模式
# ============================================================

fn apply_twice(f, x) {
    f(f(x))  # 这会失败吗？函数作为参数？
}

fn inc(x) {
    x + 1
}

# result_hof = apply_twice(inc, 5)  # 预期: 7 (如果支持高阶函数)

# ============================================================
# 攻击向量3: 闭包捕获 (如果支持)
# ============================================================

outer_var = 10

fn capture_test() {
    outer_var  # 能否访问外部变量？
}

# result_capture = capture_test()  # 预期: 10 (如果支持闭包)

# ============================================================
# 攻击向量4: 函数定义顺序依赖
# ============================================================

fn forward_call(x) {
    helper(x) + 1  # 调用后面定义的函数？
}

fn helper(y) {
    y * 2
}

result_forward = forward_call(5)  # 预期: 11 (5*2+1)

# ============================================================
# 攻击向量5: 重复定义 (应该报错或覆盖)
# ============================================================

fn duplicate() {
    1
}

fn duplicate() {
    2  # 覆盖前面的定义？
}

result_dup = duplicate()  # 预期: 2 (后定义优先)

# ============================================================
# 攻击向量6: 嵌套函数定义
# ============================================================

fn outer_fn(x) {
    fn inner_fn(y) {
        x + y  # 内部函数能否访问外部参数？
    }
    inner_fn(10)
}

# result_nested_fn = outer_fn(5)  # 预期: 15 (如果支持嵌套函数)

# ============================================================
# 攻击向量7: 函数调用自身多次 (分治)
# ============================================================

fn split_work(n) {
    if n <= 1 {
        1
    } else {
        half = n / 2
        split_work(half) + split_work(n - half)
    }
}

result_split = split_work(10)  # 预期: 10

# ============================================================
# 攻击向量8: 尾递归优化测试
# ============================================================

fn tail_recursive(n, acc) {
    if n <= 0 {
        acc
    } else {
        tail_recursive(n - 1, acc + n)
    }
}

result_tail = tail_recursive(100, 0)  # 预期: 5050

# ============================================================
# 最终汇总
# ============================================================
final_stress = result_deep + result_forward + result_dup + result_split + result_tail
