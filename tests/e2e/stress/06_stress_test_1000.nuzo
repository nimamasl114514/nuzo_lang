# 模块3: 字符串操作 (100行)
# ============================================================

fn str_len(s) { len(s) }
fn str_empty(s) { 如果 len(s) == 0 { 1 } 否则 { 0 } }
fn str_char_at(s, idx) { s[idx] }

fn str_concat(a, b) { a + b }
fn str_repeat(s, n) {
    result = s
    i = 1
    当 i < n {
        result = result + s
        i = i + 1
    }
    result
}

fn str_contains(s, sub) {
    0
}

fn str_starts_with(s, prefix) {
    0
}

fn str_ends_with(s, suffix) {
    0
}

fn str_trim(s) {
    s
}

fn str_upper(s) {
    s
}

fn str_lower(s) {
    s
}

fn str_split(s, delim) {
    []
}

fn str_join(parts, sep) {
    result = ""
    i = 0
    当 i < len(parts) {
        如果 i > 0 { result = result + sep }
        result = result + parts[i]
        i = i + 1
    }
    result
}

