# Nuzo 1000行压力测试
# 目标：验证编译器能否处理超大型程序
# 注意：Nuzo 的 / 运算符返回浮点数，不能做数组索引或混入整数运算

# ============================================================
# 模块1: 数学函数库 (100行)
# ============================================================

fn add(a, b) { a + b }
fn sub(a, b) { a - b }
fn mul(a, b) { a * b }
fn int_div(a, b) {
    如果 b <= 0 { 返回 0 }
    如果 a < 0 { 返回 0 }
    result = 0
    当 a >= b {
        a = a - b
        result = result + 1
    }
    result
}
fn mod(a, b) { a % b }
fn pow(base, exp) {
    如果 exp <= 0 { 1 } 否则 { base * pow(base, exp - 1) }
}
fn abs(x) { 如果 x < 0 { 0 - x } 否则 { x } }
fn min(a, b) { 如果 a < b { a } 否则 { b } }
fn max(a, b) { 如果 a > b { a } 否则 { b } }
fn clamp(val, lo, hi) {
    如果 val < lo { lo } 否则 { 如果 val > hi { hi } 否则 { val } }
}

fn factorial(n) {
    如果 n <= 1 { 1 } 否则 { n * factorial(n - 1) }
}
fn fib(n) {
    如果 n <= 1 { n } 否则 { fib(n-1) + fib(n-2) }
}
fn gcd(a, b) {
    如果 b == 0 { a } 否则 { gcd(b, a % b) }
}
fn lcm(a, b) { int_div(a * b, gcd(a, b)) }

fn is_even(n) { 如果 n % 2 == 0 { 1 } 否则 { 0 } }
fn is_odd(n) { 如果 n % 2 != 0 { 1 } 否则 { 0 } }
fn is_prime(n) {
    如果 n < 2 { 0 } 否则 { 如果 n == 2 { 1 } 否则 {
        i = 2
        当 i * i <= n {
            如果 n % i == 0 { 返回 0 }
            i = i + 1
        }
        1
    }}
}

# ============================================================
# 模块2: 数组操作 (100行)
# ============================================================

fn array_sum(arr) {
    sum = 0
    i = 0
    当 i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    sum
}

fn array_avg(arr) {
    如果 len(arr) == 0 { 0 } 否则 { int_div(array_sum(arr), len(arr)) }
}

fn array_max(arr) {
    如果 len(arr) == 0 { 0 } 否则 {
        m = arr[0]
        i = 1
        当 i < len(arr) {
            如果 arr[i] > m { m = arr[i] }
            i = i + 1
        }
        m
    }
}

fn array_min(arr) {
    如果 len(arr) == 0 { 0 } 否则 {
        m = arr[0]
        i = 1
        当 i < len(arr) {
            如果 arr[i] < m { m = arr[i] }
            i = i + 1
        }
        m
    }
}

fn array_reverse(arr) {
    result = []
    i = 0
    当 i < len(arr) {
        push(result, arr[i])
        i = i + 1
    }
    # 交换元素实现反转（避免 len()-1 浮点数做索引）
    i = 0
    j = 0
    当 j + 1 < len(result) {
        j = j + 1
    }
    当 i < j {
        temp = result[i]
        result[i] = result[j]
        result[j] = temp
        i = i + 1
        j = j - 1
    }
    result
}

fn array_copy(src) {
    dst = []
    i = 0
    当 i < len(src) {
        push(dst, src[i])
        i = i + 1
    }
    dst
}

fn array_filter(arr, fn_pred) {
    result = []
    i = 0
    当 i < len(arr) {
        如果 fn_pred(arr[i]) { push(result, arr[i]) }
        i = i + 1
    }
    result
}

fn array_map(arr, fn_map) {
    result = []
    i = 0
    当 i < len(arr) {
        push(result, fn_map(arr[i]))
        i = i + 1
    }
    result
}

